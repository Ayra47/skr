@use "../app.scss";
@use "../components/nav.scss";

body {
    font-family:
        -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    // background: #f0f2f5;
    height: 100vh;
}

::-webkit-scrollbar {
    width: 3px;
}
::-webkit-scrollbar-track {
    background: transparent;
}
::-webkit-scrollbar-thumb {
    background: var(--border-2);
    border-radius: 2px;
}

/* ─── Layout ─────────────────────────────────────────────────────────── */
.chat-layout {
    display: flex;
    height: calc(100vh - 28px);
}

/* ─── Sidebar ────────────────────────────────────────────────────────── */
.sidebar {
    width: 320px;
    background: var(--sidebar);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
}
.sidebar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
}
.sidebar-new-btn {
    margin-left: auto;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--panel-2);
    color: var(--text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition:
        color 0.15s,
        border-color 0.15s;

    &:hover {
        color: var(--accent);
        border-color: rgba(91, 190, 255, 0.4);
    }
}
.sidebar-filters {
    display: flex;
    gap: 6px;
    margin-bottom: 12px;
}
.sidebar-filter-btn {
    flex: 1;
    height: 30px;
    border-radius: 7px;
    border: 1px solid var(--border);
    background: var(--panel-2);
    color: var(--text-mute);
    font-size: 12.5px;
    font-family: var(--font);
    cursor: pointer;
    transition:
        color 0.15s,
        border-color 0.15s,
        background 0.15s;

    &:hover {
        color: var(--text);
    }

    &.active {
        background: rgba(91, 190, 255, 0.1);
        border-color: rgba(91, 190, 255, 0.35);
        color: var(--accent);
        font-weight: 500;
    }
}
.brand-lock {
    width: 30px;
    height: 30px;
    border: 1px solid var(--border-2);
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
}
.sidebar-brand-text h2 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
}
.sidebar-brand-text p {
    font-size: 11px;
    color: var(--text-mute);
    margin-top: 1px;
}
.sidebar-search {
    position: relative;
    margin-bottom: 10px;
}
.sidebar-search input {
    width: 100%;
    height: 34px;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 10px 0 32px;
    font-size: 13px;
    font-family: var(--font);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s;
}
.sidebar-search input::placeholder {
    color: var(--text-mute);
}
.sidebar-search input:focus {
    border-color: var(--accent);
}
.sidebar-search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-mute);
    pointer-events: none;
}
.sidebar-nav {
    display: flex;
    gap: 4px;
}
.sidebar-nav a,
.sidebar-nav button {
    flex: 1;
    padding: 5px 0;
    text-align: center;
    font-family: var(--font);
    font-size: 12px;
    letter-spacing: 0.03em;
    color: var(--text-mute);
    text-decoration: none;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    transition:
        color 0.15s,
        border-color 0.15s;
}
.sidebar-nav a:hover,
.sidebar-nav button:hover {
    color: var(--accent);
    border-color: rgba(91, 190, 255, 0.4);
}
.sidebar-nav form {
    flex: 1;
    display: flex;
}
.sidebar-nav form button {
    width: 100%;
}

/* ─── Conversation list ──────────────────────────────────────────────── */
.conversation-list {
    flex: 1;
    overflow-y: auto;
    padding: 6px 8px;
}
.conv-section-label {
    padding: 10px 8px 4px;
    font-size: 10px;
    color: var(--text-mute);
    text-transform: uppercase;
    letter-spacing: 0.12em;
}
.conversation-item {
    padding: 10px;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.1s;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 2px;
}
.conversation-item:hover {
    background: rgba(255, 255, 255, 0.03);
}
.conversation-item.active {
    background: var(--accent-soft);
}
.conversation-item.active .conv-avatar {
    border-color: var(--accent);
    color: var(--accent);
}
.conv-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    color: var(--text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 500;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
}
.online-dot {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: transparent;
    border: 2px solid var(--sidebar);
    transition: background 0.3s;
}
.online-dot::before {
    content: "";
    position: absolute;
    inset: -6px;
    z-index: -1;
    border-radius: 50%;
    background: transparent;
}
.online-dot.online {
    background: var(--green);
    box-shadow: none;
}
.online-dot.online::before {
    background: rgba(85, 214, 166, 0.18);
}
.conv-info {
    flex: 1;
    min-width: 0;
}
.conv-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.conv-preview {
    font-size: 12px;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
}
.conv-time {
    font-size: 11px;
    color: var(--text-mute);
    flex-shrink: 0;
}
.sidebar-empty {
    padding: 40px 20px;
    text-align: center;
    color: var(--text-mute);
    font-size: 13px;
    line-height: 2;
}

/* ─── Sidebar footer ─────────────────────────────────────────────────── */
.sidebar-footer {
    padding: 12px 14px;
    border-top: 1px solid var(--border);
}
.settings-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-dim);
}
.settings-row select {
    flex: 1;
    font-size: 12px;
    font-family: var(--font);
    border: 1px solid var(--border-2);
    border-radius: 6px;
    padding: 4px 8px;
    background: var(--panel-2);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s;
}
.settings-row select:focus {
    border-color: var(--accent);
}
.key-fingerprint {
    margin-top: 6px;
    font-size: 10px;
    color: var(--text-mute);
    word-break: break-all;
    letter-spacing: 0.02em;
    font-family: var(--font-mono);
}
.device-export-row {
    margin-top: 6px;
    display: flex;
    gap: 6px;
}
.export-btn {
    font-size: 11px;
    font-family: var(--font);
    background: transparent;
    border: 1px solid var(--border-2);
    color: var(--text-dim);
    border-radius: 6px;
    padding: 4px 10px;
    cursor: pointer;
    transition:
        color 0.15s,
        border-color 0.15s;
}
.export-btn:hover {
    color: var(--accent);
    border-color: rgba(91, 190, 255, 0.4);
}

/* ─── Chat pane ──────────────────────────────────────────────────────── */
.chat-pane {
    flex: 1;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    min-width: 0;
    position: relative;
}
.chat-header {
    padding: 12px 24px;
    background: var(--panel);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
    cursor: pointer;
}
.chat-header-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--accent);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 500;
    overflow: hidden;
    cursor: pointer;
}

.avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 100%;
    display: block;
}
.group-info-avatar > .avatar-img {
    border-radius: 0;
}
.chat-header-info {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border-radius: 8px;
    padding: 4px 6px;
    margin: -4px -6px;
    transition: background 0.15s;
}

.chat-header--linkable {
    .chat-header-avatar {
        transition:
            opacity 0.15s,
            box-shadow 0.15s;

        &:hover {
            opacity: 0.8;
            box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.12);
        }
    }
}
.chat-header-name {
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
}
.chat-header-status {
    font-size: 11px;
    color: var(--green);
    min-height: 14px;
    line-height: 1;
}
.chat-header-tools {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 4px;
    cursor: default;
}
.chat-tool-btn {
    width: 36px;
    height: 36px;
    border-radius: 9px;
    border: none;
    background: transparent;
    color: var(--text-mute);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
        background 0.15s,
        color 0.15s;

    &:hover {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
    }
}
.chat-header-e2e {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: var(--green);
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(109, 212, 154, 0.08);
    border: 1px solid rgba(109, 212, 154, 0.2);
    margin-left: 4px;
}
.key-change-warn {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    color: rgba(91, 190, 255, 0.9);
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(91, 190, 255, 0.08);
    border: 1px solid rgba(91, 190, 255, 0.25);
    margin-left: 4px;
    white-space: nowrap;
}

/* ─── Pin bar ────────────────────────────────────────────────────────── */
.msg-search-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border-bottom: 1px solid var(--border);
    background: var(--panel);
    color: var(--text-mute);
    flex-shrink: 0;

    input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        font-size: 13px;
        font-family: var(--font);
        color: var(--text);

        &::placeholder {
            color: var(--text-mute);
        }
    }
}
.msg-search-counter {
    font-size: 11.5px;
    color: var(--text-mute);
    white-space: nowrap;
    min-width: 40px;
    text-align: right;
}
.msg-search-nav,
.msg-search-close {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: none;
    background: transparent;
    color: var(--text-mute);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
        background 0.12s,
        color 0.12s;
    flex-shrink: 0;

    &:hover {
        background: rgba(255, 255, 255, 0.06);
        color: var(--text);
    }
    &:disabled {
        opacity: 0.3;
        cursor: default;
    }
}
.msg-search-highlight {
    background: rgba(91, 190, 255, 0.25);
    border-radius: 2px;
}
.msg-search-highlight--active {
    background: rgba(91, 190, 255, 0.55);
    border-radius: 2px;
}
.pin-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 18px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s;
    min-height: 0;
    &:hover {
        background: var(--hover);
    }
}
.pin-bar-icon {
    font-size: 14px;
    flex-shrink: 0;
    opacity: 0.7;
}
.pin-bar-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
    border-left: 2px solid var(--accent);
    padding-left: 8px;
}
.pin-bar-title {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 6px;
}
.pin-bar-counter {
    font-weight: 400;
    opacity: 0.7;
}
.pin-bar-text {
    font-size: 12.5px;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.typing-indicator {
    padding: 4px 28px;
    font-size: 12px;
    color: var(--accent);
    min-height: 24px;
    opacity: 0.75;
}

/* ─── Messages ───────────────────────────────────────────────────────── */
.messages-area {
    flex: 1;
    overflow-y: auto;
    padding: 20px 28px;
    display: flex;
    flex-direction: column;
    gap: 4px;
}
.message-bubble {
    max-width: 62%;
    padding: 9px 13px 7px;
    font-size: 14px;
    line-height: 1.55;
    word-break: break-word;
    animation: msgIn 0.15s ease;
}
@keyframes msgIn {
    from {
        opacity: 0;
        transform: translateY(4px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
.message-bubble.own {
    align-self: flex-end;
    background: linear-gradient(
        180deg,
        rgba(91, 190, 255, 0.16),
        rgba(200, 133, 58, 0.1)
    );
    border: 1px solid rgba(91, 190, 255, 0.25);
    border-radius: 14px 14px 4px 14px;
    color: var(--text);
}
.message-bubble.other {
    align-self: flex-start;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 14px 14px 14px 4px;
    color: var(--text);
}
.group-message-row {
    align-self: flex-start;
    display: flex;
    align-items: flex-end;
    gap: 8px;
    max-width: 72%;
}
.group-message-row .message-bubble.other {
    max-width: none;
}
.group-message-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    color: var(--text-dim);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 500;
    flex-shrink: 0;
    overflow: hidden;
}
.group-message-sender {
    color: var(--accent);
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1.2;
    margin-bottom: 2px;
}
.message-meta {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    margin-top: 3px;
    font-size: 10.5px;
    color: var(--text-mute);
}
.system-message {
    align-self: center;
    max-width: 80%;
    padding: 6px 10px;
    color: var(--text-dim);
    font-size: 13px;
    line-height: 1.4;
    text-align: center;
}
.ctx-menu {
    position: fixed;
    z-index: 2000;
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    overflow: hidden;
    min-width: 160px;
    padding: 4px 0;
    animation: ctxIn 0.1s ease;
    user-select: none;
}
@keyframes ctxIn {
    from {
        opacity: 0;
        transform: scale(0.95);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}
.ctx-item {
    display: block;
    width: 100%;
    padding: 9px 16px;
    text-align: left;
    background: none;
    border: none;
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    cursor: pointer;
    transition: background 0.1s;
    &:hover {
        background: var(--panel-3);
    }
}
.ctx-item--danger {
    color: #e05555;
}
.reply-preview-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    border-top: 1px solid var(--border);
    border-left: 3px solid rgba(91, 190, 255, 0.6);
    background: var(--panel-2);
    border-radius: 4px 4px 0 0;
    animation: msgIn 0.12s ease;
}
.reply-preview-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
}
.reply-preview-alias {
    font-size: 12px;
    font-weight: 600;
    color: rgba(91, 190, 255, 0.9);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.reply-preview-snippet {
    font-size: 12px;
    color: var(--text-mute);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.reply-preview-cancel {
    flex-shrink: 0;
    background: none;
    border: none;
    color: var(--text-mute);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 0 2px;
    &:hover {
        color: var(--text);
    }
}
/* ─── Forwarded header ───────────────────────────────────────────────── */
.forwarded-header {
    font-size: 11.5px;
    color: var(--accent);
    margin-bottom: 4px;
    opacity: 0.85;
}

/* ─── Forward modal ──────────────────────────────────────────────────── */
.forward-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}
.forward-modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    width: 320px;
    max-height: 480px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.forward-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    font-weight: 500;
}
.forward-modal-close {
    background: none;
    border: none;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    color: var(--text-secondary);
    padding: 0 2px;
}
.forward-conv-list {
    flex: 1;
    overflow-y: auto;
    padding: 8px 0;
}
.forward-conv-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    cursor: pointer;
    transition: background 0.15s;
    &:hover {
        background: var(--hover);
    }
    input[type="checkbox"] {
        width: 16px;
        height: 16px;
        accent-color: var(--accent);
        cursor: pointer;
        flex-shrink: 0;
    }
}
.forward-conv-name {
    font-size: 13.5px;
}
.forward-modal-footer {
    display: flex;
    gap: 8px;
    padding: 12px 18px;
    border-top: 1px solid var(--border);
    justify-content: flex-end;
}
.forward-btn {
    padding: 7px 18px;
    border-radius: 8px;
    border: 1px solid var(--border-2);
    font-size: 13px;
    cursor: pointer;
    transition: background 0.15s;
    &--cancel {
        background: transparent;
        color: var(--text-secondary);
        &:hover {
            background: var(--hover);
        }
    }
    &--send {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
        &:disabled {
            opacity: 0.45;
            cursor: default;
        }
        &:not(:disabled):hover {
            filter: brightness(1.1);
        }
    }
}

.reply-quote {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 5px 9px;
    margin-bottom: 5px;
    border-left: 3px solid rgba(91, 190, 255, 0.55);
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.04);
    cursor: pointer;
    transition: background 0.15s;
    &:hover {
        background: rgba(255, 255, 255, 0.08);
    }
}
.reply-quote-alias {
    font-size: 11px;
    font-weight: 600;
    color: rgba(91, 190, 255, 0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.reply-quote-text {
    font-size: 12px;
    color: var(--text-mute);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 260px;
}
@keyframes msgHighlight {
    0%,
    100% {
        box-shadow: none;
    }
    30% {
        box-shadow: 0 0 0 2px rgba(91, 190, 255, 0.5);
    }
}
.msg-highlight {
    animation: msgHighlight 1.5s ease;
}
/* ─── Select mode ────────────────────────────────────────────────────── */
.msg-selected {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 12px;
}
.select-toolbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--surface);
    border-top: 1px solid var(--border);
    flex-shrink: 0;
}
.select-toolbar-count {
    flex: 1;
    font-size: 13px;
    color: var(--text-secondary);
}
.select-toolbar-btn {
    padding: 6px 14px;
    border-radius: 8px;
    border: 1px solid var(--border-2);
    background: transparent;
    color: var(--text);
    font-size: 13px;
    cursor: pointer;
    transition: background 0.15s;
    &:hover {
        background: var(--hover);
    }
    &--danger {
        color: #e55;
        border-color: #e55;
        &:hover {
            background: rgba(238, 85, 85, 0.08);
        }
    }
}

.delete-msg-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}
.delete-msg-modal {
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px 20px 16px;
    width: min(320px, 90vw);
    display: flex;
    flex-direction: column;
    gap: 16px;
}
.delete-msg-title {
    margin: 0;
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    text-align: center;
}
.delete-group-subtitle {
    margin: -8px 0 0;
    color: var(--text-mute);
    font-size: 13px;
    line-height: 1.45;
    text-align: center;
}
.delete-msg-btns {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.delete-msg-btn {
    padding: 10px;
    border-radius: 9px;
    border: none;
    font-family: var(--font);
    font-size: 14px;
    cursor: pointer;
    transition: opacity 0.15s;
    &:hover {
        opacity: 0.85;
    }
}
.delete-msg-btn--all {
    background: rgba(224, 85, 85, 0.15);
    color: #e05555;
    border: 1px solid rgba(224, 85, 85, 0.25);
}
.delete-msg-btn--me {
    background: var(--panel-3);
    color: var(--text);
    border: 1px solid var(--border-2);
}
.delete-msg-btn--cancel {
    background: transparent;
    color: var(--text-mute);
    border: 1px solid transparent;
}
.edited-badge {
    cursor: pointer;
    color: var(--text-mute);
    font-size: 10px;
    opacity: 0.7;
    transition: opacity 0.15s;
    &:hover {
        opacity: 1;
        text-decoration: underline;
    }
}
.edit-inline-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.edit-inline-input {
    width: 100%;
    min-width: 180px;
    padding: 6px 8px;
    border-radius: 8px;
    border: 1px solid var(--border-2);
    background: var(--panel-3);
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    line-height: 1.5;
    resize: none;
    outline: none;
    box-sizing: border-box;
    &:focus {
        border-color: rgba(91, 190, 255, 0.5);
    }
}
.edit-inline-btns {
    display: flex;
    gap: 6px;
    justify-content: flex-end;
    button {
        padding: 3px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-family: var(--font);
        cursor: pointer;
        border: 1px solid var(--border-2);
        transition: opacity 0.15s;
        &:hover {
            opacity: 0.8;
        }
        &:disabled {
            opacity: 0.4;
            cursor: default;
        }
    }
}
.edit-save-btn {
    background: rgba(91, 190, 255, 0.18);
    color: var(--text);
}
.edit-cancel-btn {
    background: transparent;
    color: var(--text-mute);
}
.edit-history-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
}
.edit-history-modal {
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    width: min(400px, 90vw);
    max-height: 70vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}
.edit-history-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px 12px;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
}
.edit-history-close {
    background: none;
    border: none;
    color: var(--text-mute);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 0 2px;
    &:hover {
        color: var(--text);
    }
}
.edit-history-list {
    overflow-y: auto;
    padding: 8px 0;
    flex: 1;
}
.edit-history-entry {
    padding: 10px 16px;
    border-bottom: 1px solid var(--border);
    &:last-child {
        border-bottom: none;
    }
}
.edit-history-time {
    font-size: 11px;
    color: var(--text-mute);
    margin-bottom: 4px;
}
.edit-history-text {
    font-size: 13px;
    color: var(--text-dim);
    white-space: pre-wrap;
    word-break: break-word;
}
.load-more-btn {
    align-self: center;
    margin: 10px 0;
    padding: 5px 14px;
    font-size: 12px;
    font-family: var(--font);
    background: transparent;
    border: 1px solid var(--border-2);
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-dim);
    transition:
        color 0.15s,
        border-color 0.15s;
}
.load-more-btn:hover {
    color: var(--accent);
    border-color: rgba(91, 190, 255, 0.4);
}

/* ─── Composer ───────────────────────────────────────────────────────── */
.input-area {
    padding: 14px 24px 18px;
    background: var(--panel);
    border-top: 1px solid var(--border);
}
.composer-box {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    border-radius: 14px;
    padding: 8px 8px 8px 14px;
    transition:
        border-color 0.2s,
        box-shadow 0.2s;
}
.composer-box:focus-within {
    border-color: rgba(91, 190, 255, 0.3);
    box-shadow: 0 0 0 3px rgba(91, 190, 255, 0.07);
}
.composer-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--text-mute);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: color 0.15s;
}
.composer-btn:hover {
    color: var(--text-dim);
}
.composer-textarea {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-size: 14px;
    font-family: var(--font);
    resize: none;
    padding: 8px 0;
    min-height: 24px;
    max-height: 120px;
    line-height: 1.5;
}
.composer-textarea::placeholder {
    color: var(--text-mute);
}
.send-btn {
    width: 38px;
    height: 38px;
    border-radius: 9px;
    border: none;
    background: var(--border-2);
    color: var(--text-mute);
    cursor: not-allowed;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
}
.send-btn.active {
    background: linear-gradient(180deg, var(--accent), var(--accent-deep));
    color: #061426;
    cursor: pointer;
    box-shadow: 0 6px 18px rgba(91, 190, 255, 0.25);
}
// ─── Upload progress ─────────────────────────────────────────────────────────
.upload-progress {
    margin-bottom: 8px;
    border-radius: 8px;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 10px;

    &[hidden] {
        display: none;
    }
}
.upload-progress-bar {
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    width: 0%;
    transition: width 0.2s;
    flex-shrink: 0;
    min-width: 0;
    flex: 1;
    max-width: 200px;
}
.upload-progress-label {
    font-size: 12px;
    color: var(--text-mute);
    white-space: nowrap;
}

// ─── File bubble ──────────────────────────────────────────────────────────────
.file-bubble {
    max-width: 320px;
}
.file-preview {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 4px 0;
}
.file-preview--generic {
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    padding: 10px 12px;
}
.file-preview--image,
.file-preview--video,
.file-preview--audio {
    flex-direction: column;
    align-items: flex-start;
}
.file-loading {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}
.file-icon {
    font-size: 18px;
    line-height: 1;
}
.file-ext-badge {
    font-size: 10px;
    font-weight: 700;
    font-family: var(--font-mono, monospace);
    letter-spacing: 0.04em;
    color: var(--accent);
    background: var(--accent-soft);
    border: 1px solid rgba(91, 190, 255, 0.25);
    border-radius: 5px;
    padding: 3px 6px;
    flex-shrink: 0;
    min-width: 32px;
    text-align: center;
}
.file-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
    min-width: 0;
}
.file-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 200px;
}
.file-size {
    font-size: 11px;
    color: var(--text-mute);
}
.file-load-btn,
.file-download-btn {
    font-size: 12px;
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-2);
    background: var(--panel-2);
    color: var(--accent);
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;

    &:hover:not(:disabled) {
        background: var(--border-2);
    }
    &:disabled {
        opacity: 0.5;
        cursor: default;
    }
}
.file-media {
    width: 100%;
}
.file-img {
    max-width: 280px;
    max-height: 320px;
    border-radius: 8px;
    display: block;
}
.file-video {
    max-width: 280px;
    border-radius: 8px;
    display: block;
}
.file-audio {
    width: 240px;
    margin-top: 4px;
}
.file-caption {
    font-size: 13px;
    color: var(--text);
    margin-top: 4px;
}
.file-expiry-warn {
    font-size: 11px;
    color: rgba(91, 190, 255, 0.67);
    margin-top: 4px;
}
.file-media--loading {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    min-width: 80px;
}
.file-spinner {
    width: 20px;
    height: 20px;
    border: 2px solid var(--border-2);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: file-spin 0.7s linear infinite;
    display: inline-block;
}
@keyframes file-spin {
    to {
        transform: rotate(360deg);
    }
}
.file-error {
    font-size: 12px;
    color: var(--text-mute);
}
.photo-clickable {
    cursor: zoom-in;
}

// ─── Chat more menu ───────────────────────────────────────────────────────────
.chat-more-wrap {
    position: relative;
    flex-shrink: 0;
}
.chat-more-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    background: var(--panel);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    padding: 4px;
    display: none;
    flex-direction: column;
    gap: 2px;
    min-width: 150px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    z-index: 100;

    &.chat-more-menu--open {
        display: flex;
    }
}
.chat-more-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font: inherit;
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    transition:
        background 0.12s,
        color 0.12s;

    &:hover {
        background: var(--panel-2);
        color: var(--text);
    }

    svg {
        flex-shrink: 0;
        color: var(--text-mute);
    }

    &.chat-more-item--danger {
        color: var(--danger);

        svg {
            color: var(--danger);
        }

        &:hover {
            background: rgba(232, 123, 109, 0.08);
            color: var(--danger);
        }
    }
}

// ─── Attach menu ──────────────────────────────────────────────────────────────
.attach-wrap {
    position: relative;
    flex-shrink: 0;
}
.attach-menu {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    background: var(--panel);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    padding: 4px;
    display: none;
    flex-direction: column;
    gap: 2px;
    min-width: 130px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
    z-index: 100;

    &.attach-menu--open {
        display: flex;
    }
}
.attach-menu-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 7px;
    border: none;
    background: transparent;
    color: var(--text-dim);
    font-size: 13px;
    cursor: pointer;
    text-align: left;
    transition:
        background 0.12s,
        color 0.12s;

    &:hover {
        background: var(--panel-2);
        color: var(--text);
    }

    svg {
        flex-shrink: 0;
        color: var(--text-mute);
    }
}

// ─── Lightbox ─────────────────────────────────────────────────────────────────
.lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
}
.lightbox-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.6);
    font-size: 22px;
    cursor: pointer;
    line-height: 1;
    padding: 4px 8px;
    border-radius: 6px;
    transition: color 0.15s;

    &:hover {
        color: #fff;
    }
}
.lightbox-img-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 92vw;
    max-height: 80vh;
    overflow: hidden;
    cursor: grab;

    &:active {
        cursor: grabbing;
    }
}
.lightbox-img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 6px;
    display: block;
    transform-origin: center;
    user-select: none;
    -webkit-user-drag: none;
}
.lightbox-dl-btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    padding: 6px 16px;
    border-radius: 8px;
    cursor: pointer;
    transition:
        border-color 0.15s,
        color 0.15s;

    &:hover:not(:disabled) {
        border-color: rgba(255, 255, 255, 0.5);
        color: #fff;
    }
    &:disabled {
        opacity: 0.5;
        cursor: default;
    }
}

// ─── Location bubble ──────────────────────────────────────────────────────────
.location-bubble {
    max-width: 280px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border-2);
}
.location-map-tile {
    width: 280px;
    height: 160px;

    // Leaflet attribution fix
    .leaflet-container {
        width: 100%;
        height: 100%;
        font-size: 11px;
    }
}
.location-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    padding: 7px 10px;
    background: var(--panel-2);
    flex-wrap: wrap;
}
.location-live-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
    min-width: 0;
}
.location-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e74c3c;
    flex-shrink: 0;
    animation: loc-pulse 1.4s ease-in-out infinite;
}
@keyframes loc-pulse {
    0%,
    100% {
        opacity: 1;
        transform: scale(1);
    }
    50% {
        opacity: 0.4;
        transform: scale(0.7);
    }
}
.location-live-label {
    font-size: 11px;
    color: var(--text-mute);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.location-stop-btn {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 5px;
    border: 1px solid rgba(231, 76, 60, 0.4);
    background: transparent;
    color: #e74c3c;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.12s;
    flex-shrink: 0;

    &:hover:not(:disabled) {
        background: rgba(231, 76, 60, 0.1);
    }
    &:disabled {
        opacity: 0.5;
        cursor: default;
    }
}
.location-fs-btn {
    font-size: 11px;
    padding: 3px 8px;
    border-radius: 5px;
    border: 1px solid var(--border-2);
    background: transparent;
    color: var(--accent);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.12s;
    flex-shrink: 0;

    &:hover {
        background: var(--panel);
    }
}

// ─── Location fullscreen overlay ──────────────────────────────────────────────
.location-fs-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: var(--panel);
    display: flex;
    flex-direction: column;
}
.location-fs-close {
    position: absolute;
    top: 14px;
    right: 16px;
    z-index: 401;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    color: var(--text-dim);
    font-size: 18px;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;

    &:hover {
        color: var(--text);
    }
}
.location-fs-map {
    flex: 1;

    .leaflet-container {
        width: 100%;
        height: 100%;
    }
}

// ─── Location modal ───────────────────────────────────────────────────────────
.location-modal-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 4px;
}
.location-modal-label {
    font-size: 12px;
    color: var(--text-mute);
    font-weight: 500;
}
.location-modal-divider {
    height: 1px;
    background: var(--border);
    margin: 8px 0;
}
.location-duration-btns {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
}
.location-duration-btn {
    padding: 6px 14px;
    border-radius: 8px;
    border: 1px solid var(--border-2);
    background: var(--panel-2);
    color: var(--text-dim);
    font-size: 13px;
    cursor: pointer;
    transition:
        border-color 0.12s,
        color 0.12s,
        background 0.12s;

    &:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: var(--accent-soft);
    }
}

// ─── Emoji panel (desktop: inline flex column, mobile: bottom sheet) ──────────
.emoji-panel {
    width: 0;
    overflow: hidden;
    flex-shrink: 0;
    border-left: 0px solid var(--border);
    background: var(--panel);
    display: flex;
    flex-direction: column;
    transition:
        width 0.22s cubic-bezier(0.4, 0, 0.2, 1),
        border-left-width 0s 0.22s;

    .emoji-picker-host,
    em-emoji-picker {
        --background-rgb: 22, 25, 34;
        --font-family: var(--font);
        --shadow: none;
        display: block;
        width: 352px;
        height: 100%;
    }

    .emoji-picker-host {
        min-height: 0;
        flex: 1;
    }

    &--open {
        width: 352px;
        border-left-width: 1px;
        transition:
            width 0.22s cubic-bezier(0.4, 0, 0.2, 1),
            border-left-width 0s;
    }
}

.chat-side-panel-body {
    min-height: 0;
    flex: 1;
    display: grid;
}

.chat-side-panel-view {
    min-width: 0;
    min-height: 0;
    display: none;
    overflow: hidden;

    &.is-active {
        display: flex;
        flex-direction: column;
    }
}

.chat-side-panel-view--info {
    overflow-y: auto;
}

.chat-side-panel-view--emoji {
    overflow: hidden;
}

.chat-side-panel-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    padding: 10px 12px;
    border-top: 1px solid var(--border);
    background: rgba(8, 11, 18, 0.96);
}

.chat-side-panel-tab {
    min-width: 0;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 0;
    border-radius: 12px;
    background: transparent;
    color: var(--text-mute);
    font: 700 13px var(--font);
    cursor: pointer;
    transition:
        color 0.15s,
        background 0.15s;

    &.is-active {
        color: var(--accent);
        background: rgba(91, 190, 255, 0.12);
    }
}

.direct-info-panel {
    padding: 28px 24px;
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.6;
}

// Mobile: bottom sheet
.emoji-backdrop {
    display: none;
}

@media (max-width: 768px) {
    .emoji-backdrop {
        display: block;
        position: fixed;
        inset: 0;
        z-index: 999;
        background: rgba(0, 0, 0, 0.45);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;

        &--open {
            opacity: 1;
            pointer-events: auto;
        }
    }

    .emoji-panel {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        width: auto !important;
        height: 0;
        z-index: 1000;
        border-left: none;
        border-top: 1px solid var(--border);
        border-radius: 16px 16px 0 0;
        overflow: hidden;
        transition: height 0.25s cubic-bezier(0.4, 0, 0.2, 1);

        &--open {
            height: 420px;
            width: auto !important;
        }

        .emoji-picker-host,
        em-emoji-picker {
            width: 100% !important;
            height: 360px !important;
            border-radius: 0;
        }
    }
}

.composer-hint {
    font-size: 10.5px;
    color: var(--text-mute);
    letter-spacing: 0.04em;
    margin-top: 8px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
}

/* ─── Empty state ────────────────────────────────────────────────────── */
.no-chat-selected {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    position: relative;
    overflow: hidden;
}
.empty-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
        circle,
        rgba(91, 190, 255, 0.1),
        transparent 60%
    );
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    filter: blur(60px);
    pointer-events: none;
}
.empty-lock-box {
    width: 110px;
    height: 110px;
    background: linear-gradient(160deg, #2a2316 0%, #1c1a14 100%);
    border: 1px solid rgba(91, 190, 255, 0.18);
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    position: relative;
    z-index: 1;
    box-shadow: 0 8px 40px rgba(91, 190, 255, 0.08);
}
.empty-title {
    font-size: 22px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
}
.empty-subtitle {
    font-size: 13.5px;
    color: var(--text-dim);
    text-align: center;
    line-height: 1.6;
    max-width: 360px;
    position: relative;
    z-index: 1;
    margin-top: -4px;
}
.empty-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 12px;
    color: var(--text-dim);
    background: var(--panel-2);
    position: relative;
    z-index: 1;
    font-family: var(--font-mono);
    margin-top: 4px;
}
.empty-badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(74, 222, 128, 0.6);
}
.empty-shortcuts {
    display: flex;
    align-items: center;
    gap: 20px;
    position: relative;
    z-index: 1;
    margin-top: 6px;
}
.empty-shortcut {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-mute);

    kbd {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 26px;
        height: 26px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--panel-2);
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--text-dim);
        font-style: normal;
    }
}

/* ─── E2E notice ─────────────────────────────────────────────────────── */
.e2e-notice {
    align-self: center;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: var(--text-mute);
    padding: 6px 14px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 999px;
}

/* ─── Key warning ────────────────────────────────────────────────────── */
.key-warning {
    background: rgba(91, 190, 255, 0.07);
    border-bottom: 1px solid rgba(91, 190, 255, 0.2);
    color: var(--accent);
    padding: 10px 24px;
    font-size: 12px;
    line-height: 1.6;
}

/* ─── Modals ─────────────────────────────────────────────────────────── */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 400;
    display: flex;
    align-items: center;
    justify-content: center;
}
.modal-box {
    background: var(--panel);
    border: 1px solid var(--border-2);
    border-radius: 16px;
    padding: 28px;
    width: 360px;
    max-width: calc(100vw - 40px);
    display: flex;
    flex-direction: column;
    gap: 14px;
}
.modal-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
}
.modal-subtitle {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.5;
    margin-top: -4px;
}
.modal-input {
    width: 100%;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 20px;
    font-family: var(--font-mono);
    color: var(--text);
    outline: none;
    letter-spacing: 0.3em;
    text-align: center;
    transition: border-color 0.15s;
    box-sizing: border-box;
}
.modal-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(91, 190, 255, 0.07);
}
.modal-textarea {
    width: 100%;
    background: var(--panel-2);
    border: 1px solid var(--border-2);
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 11px;
    font-family: var(--font-mono);
    color: var(--text);
    outline: none;
    resize: vertical;
    transition: border-color 0.15s;
    box-sizing: border-box;
    line-height: 1.6;
}
.modal-textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(91, 190, 255, 0.07);
}
.modal-error {
    font-size: 12px;
    color: #e86a5b;
    min-height: 16px;
    margin-top: -6px;
}

/* ─── 2026 dark chat redesign overrides ─────────────────────────────── */
body {
    overflow: hidden;
}

body:has(.chat-layout) {
    background:
        radial-gradient(
            circle at 18% 0%,
            rgba(91, 190, 255, 0.14),
            transparent 34%
        ),
        radial-gradient(
            circle at 86% 10%,
            rgba(138, 180, 248, 0.055),
            transparent 31%
        ),
        linear-gradient(180deg, #080a10 0%, #05070b 55%, #030407 100%);
}

.chat-layout {
    height: calc(100vh - 28px);
    width: min(100% - 40px, 1660px);
    margin: 14px auto;
    display: flex;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.085);
    border-radius: 22px;
    background:
        linear-gradient(180deg, rgba(13, 17, 27, 0.78), rgba(5, 7, 11, 0.94)),
        radial-gradient(
            circle at 58% 18%,
            rgba(91, 190, 255, 0.08),
            transparent 30%
        );
    box-shadow: 0 28px 90px rgba(0, 0, 0, 0.52);
    isolation: isolate;
}

.sidebar {
    width: 340px;
    background: linear-gradient(
        180deg,
        rgba(14, 17, 27, 0.96),
        rgba(9, 11, 18, 0.94)
    );
    border-right-color: rgba(255, 255, 255, 0.08);
    box-shadow: inset -1px 0 rgba(255, 255, 255, 0.026);
    backdrop-filter: blur(22px);
}

.sidebar-header {
    padding: 16px;
    min-height: 76px;

    border-bottom: 1px solid var(--border);
    margin-bottom: 16px;

    background: linear-gradient(
        180deg,
        rgba(220, 238, 255, 0.04),
        rgba(255, 255, 255, 0.008)
    );
}

.brand-lock {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(91, 190, 255, 0.4);
    border-radius: 13px;
    color: #061426;
    background: linear-gradient(145deg, var(--accent), var(--accent-deep));
    box-shadow:
        inset 0 1px rgba(255, 255, 255, 0.35),
        0 12px 30px rgba(91, 190, 255, 0.18);
}

.sidebar-brand-text h2 {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0;
}

.sidebar-brand-text p {
    color: var(--text-mute);
    font-family: var(--font-mono, ui-monospace);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.sidebar-new-btn,
.chat-tool-btn,
.composer-btn,
.msg-search-nav,
.msg-search-close {
    border: 1px solid rgba(255, 255, 255, 0.075);
    background: rgba(255, 255, 255, 0.035);
    color: var(--text-mute);
    border-radius: 12px;
}

.sidebar-new-btn {
    width: 36px;
    height: 36px;
}

.sidebar-new-btn:hover,
.chat-tool-btn:hover,
.composer-btn:hover,
.msg-search-nav:hover,
.msg-search-close:hover {
    color: var(--text);
    border-color: rgba(91, 190, 255, 0.25);
    background: rgba(255, 255, 255, 0.06);
}

.sidebar-search {
    margin-bottom: 12px;
}

.sidebar-wrapper {
    padding: 0 22px;
    position: relative;
}

.sidebar-search input {
    height: 44px;
    border-color: rgba(255, 255, 255, 0.085);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.035);
    padding-left: 38px;
    color: var(--text);
}

.sidebar-search input:focus {
    border-color: rgba(91, 190, 255, 0.42);
    box-shadow: 0 0 0 4px rgba(91, 190, 255, 0.08);
}

.sidebar-search-icon {
    left: 14px;
}

.sidebar-filters {
    gap: 8px;
}

.sidebar-filter-btn {
    height: 32px;
    border-color: transparent;
    border-radius: 12px;
    background: transparent;
    color: var(--text-mute);
}

.sidebar-filter-btn:hover {
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.035);
}

.sidebar-filter-btn.active {
    color: var(--accent);
    border-color: rgba(91, 190, 255, 0.26);
    background: rgba(91, 190, 255, 0.1);
    font-weight: 650;
}

.conversation-list {
    padding: 6px 10px 14px;
}

.conversation-item {
    position: relative;
    gap: 12px;
    padding: 12px 10px;
    margin-bottom: 4px;
    border-radius: 16px;
    color: var(--text-dim);
    transition:
        background 0.16s ease,
        box-shadow 0.16s ease,
        color 0.16s ease;
}

.conversation-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 3px;
    border-radius: 999px;
    background: transparent;
}

.conversation-item:hover {
    background: rgba(255, 255, 255, 0.04);
}

.conversation-item.active {
    background: linear-gradient(
        180deg,
        rgba(91, 190, 255, 0.12),
        rgba(91, 190, 255, 0.045)
    );
    box-shadow: inset 0 0 0 1px rgba(91, 190, 255, 0.18);
}

.conversation-item.active::before {
    background: var(--accent);
    box-shadow: 0 0 14px rgba(91, 190, 255, 0.55);
}

.conversation-item.active .conv-avatar {
    color: var(--text);
    border-color: rgba(91, 190, 255, 0.34);
}

.conv-avatar,
.chat-header-avatar,
.group-message-avatar,
.group-member-avatar {
    background: linear-gradient(
        145deg,
        rgba(91, 190, 255, 0.22),
        rgba(91, 190, 255, 0.08)
    );
    border-color: rgba(91, 190, 255, 0.22);
    color: #d8efff;
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.08);
}

.conv-avatar {
    width: 40px;
    height: 40px;
    font-weight: 700;
    overflow: visible;
}

.conv-avatar > .avatar-img {
    border-radius: inherit;
}

.online-dot {
    right: 1px;
    bottom: 1px;
    width: 10px;
    height: 10px;
    border-color: #0b0f18;
    z-index: 2;
    overflow: visible;
}

.online-dot.online {
    background: var(--green);
    box-shadow: none;
}

.online-dot.online::before {
    inset: -4px;
    background: rgba(85, 214, 166, 0.16);
}

.conv-name {
    font-size: 13.5px;
    font-weight: 700;
}

.conv-preview,
.conv-time {
    color: var(--text-mute);
}

.sidebar-footer {
    margin: 0 10px 12px;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.075);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
}

.settings-row select,
.export-btn,
.modal-input,
.modal-textarea {
    border-color: rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
}

.export-btn:hover {
    color: var(--accent);
    border-color: rgba(91, 190, 255, 0.35);
}

.chat-pane {
    background:
        linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.014) 1px, transparent 1px),
        radial-gradient(
            circle at 50% 20%,
            rgba(91, 190, 255, 0.08),
            transparent 33%
        ),
        #06090e;
    background-size:
        42px 42px,
        42px 42px,
        auto,
        auto;
}

.chat-header {
    min-height: 76px;
    padding: 0 22px;
    background: rgba(9, 13, 21, 0.82);
    border-bottom-color: rgba(255, 255, 255, 0.075);
    backdrop-filter: blur(18px);
}

.chat-header-avatar {
    width: 42px;
    height: 42px;
    font-size: 14px;
    font-weight: 700;
}

.chat-header-info {
    min-width: 0;
    gap: 3px;
}

.chat-header-title-row {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
    flex-wrap: wrap;
}

.chat-header-name {
    font-size: 15px;
    font-weight: 750;
    line-height: 1.1;
}

.chat-header-status {
    color: var(--text-mute);
    font-size: 12px;
    line-height: 1.15;
}

.chat-header-status:not(:empty)::before {
    content: "";
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-right: 6px;
    border-radius: 999px;
    background: var(--green);
    box-shadow: 0 0 7px rgba(97, 211, 148, 0.75);
    vertical-align: 1px;
}

.chat-header-e2e,
.key-change-warn {
    margin-left: 0;
    border-radius: 999px;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
}

.chat-header-e2e {
    color: #9bd8ff;
    border-color: rgba(91, 190, 255, 0.25);
    background: rgba(91, 190, 255, 0.08);
}

.key-change-warn {
    color: #aeb8c9;
    border-color: rgba(255, 255, 255, 0.085);
    background: rgba(255, 255, 255, 0.04);
    text-transform: none;
    letter-spacing: 0;
}

.chat-header-tools {
    gap: 6px;
}

.chat-tool-btn {
    width: 38px;
    height: 38px;
}

.msg-search-bar,
.pin-bar,
.key-warning {
    background: rgba(12, 16, 25, 0.92);
    border-color: rgba(255, 255, 255, 0.075);
}

.typing-indicator {
    min-height: 30px;
    padding: 6px 28px 0;
    color: #8ccfff;
}

.messages-area {
    padding: 26px 30px;
    gap: 8px;
}

.message-bubble {
    max-width: min(62%, 560px);
    padding: 10px 14px 8px;
    border-radius: 16px;
    color: var(--text);
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.18);
}

.message-bubble.own {
    background: linear-gradient(
        180deg,
        rgba(45, 124, 177, 0.42),
        rgba(22, 74, 108, 0.36)
    );
    border-color: rgba(91, 190, 255, 0.24);
    border-radius: 16px 16px 6px 16px;
}

.message-bubble.other {
    background: linear-gradient(
        180deg,
        rgba(26, 31, 45, 0.92),
        rgba(20, 24, 36, 0.9)
    );
    border-color: rgba(255, 255, 255, 0.075);
    border-radius: 16px 16px 16px 6px;
}

.message-meta {
    color: #7f899d;
}

.system-message,
.e2e-notice {
    color: var(--text-mute);
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid rgba(255, 255, 255, 0.075);
    border-radius: 999px;
}

.input-area {
    padding: 14px 24px 18px;
    background: linear-gradient(
        180deg,
        rgba(6, 9, 14, 0),
        rgba(6, 9, 14, 0.96) 24%
    );
    border-top-color: rgba(255, 255, 255, 0.06);
}

.composer-box {
    min-height: 62px;
    align-items: center;
    border-color: rgba(255, 255, 255, 0.075);
    border-radius: 18px;
    background: rgba(16, 20, 31, 0.92);
    box-shadow: 0 18px 54px rgba(0, 0, 0, 0.28);
}

.composer-box:focus-within {
    border-color: rgba(91, 190, 255, 0.35);
    box-shadow:
        0 0 0 4px rgba(91, 190, 255, 0.075),
        0 18px 54px rgba(0, 0, 0, 0.28);
}

.composer-textarea {
    color: var(--text);
    font-size: 14px;
}

.composer-textarea::placeholder {
    color: var(--text-mute);
}

.send-btn {
    width: 40px;
    height: 40px;
    border-radius: 13px;
    background: rgba(255, 255, 255, 0.055);
}

.send-btn.active {
    color: #061426;
    background: linear-gradient(180deg, #72caff, #2f8fda);
    box-shadow: 0 10px 26px rgba(91, 190, 255, 0.25);
}

.composer-hint {
    max-width: calc(100% - 24px);
    margin: 9px auto 0;
    color: #566177;
}

.no-chat-selected {
    background:
        radial-gradient(
            circle at 50% 48%,
            rgba(91, 190, 255, 0.1),
            transparent 32%
        ),
        transparent;
}

.empty-glow {
    background: radial-gradient(
        circle,
        rgba(91, 190, 255, 0.12),
        transparent 60%
    );
}

.empty-lock-box {
    color: #d8efff;
    background: linear-gradient(
        145deg,
        rgba(91, 190, 255, 0.22),
        rgba(91, 190, 255, 0.08)
    );
    border-color: rgba(91, 190, 255, 0.22);
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(91, 190, 255, 0.08);
}

.empty-badge,
.empty-shortcut kbd {
    background: rgba(255, 255, 255, 0.035);
    border-color: rgba(255, 255, 255, 0.075);
}

.ctx-menu,
.forward-modal,
.delete-msg-modal,
.edit-history-modal,
.modal-box,
.chat-more-menu,
.attach-menu {
    background: rgba(13, 17, 27, 0.98);
    border-color: rgba(255, 255, 255, 0.085);
    box-shadow: 0 20px 58px rgba(0, 0, 0, 0.42);
}

.reply-preview-bar,
.reply-quote {
    border-left-color: rgba(91, 190, 255, 0.62);
}

.reply-preview-alias,
.reply-quote-alias,
.forwarded-header,
.group-message-sender,
.file-ext-badge {
    color: var(--accent);
}

.file-ext-badge {
    background: var(--accent-soft);
    border-color: rgba(91, 190, 255, 0.25);
}

@media (max-width: 980px) {
    .chat-layout {
        width: calc(100% - 20px);
        height: calc(100vh - 20px);
        margin: 10px;
    }

    .sidebar {
        width: 300px;
    }

    .message-bubble {
        max-width: 78%;
    }
}

@media (max-width: 720px) {
    body {
        overflow: hidden;
    }

    .chat-layout {
        width: 100%;
        height: 100dvh;
        margin: 0;
        border-right: 0;
        border-left: 0;
        border-radius: 0;
    }

    .sidebar {
        width: 82px;
    }

    .sidebar-header {
        padding: 12px 10px;
    }

    .sidebar-brand {
        justify-content: center;
    }

    .sidebar-brand-text,
    .sidebar-search,
    .sidebar-filters,
    .conv-info,
    .conv-time,
    .sidebar-footer {
        display: none;
    }

    .sidebar-new-btn {
        display: none;
    }

    .conversation-list {
        padding: 8px;
    }

    .conversation-item {
        justify-content: center;
        padding: 10px;
    }

    .chat-header {
        min-height: 68px;
        padding: 0 12px;
    }

    .chat-header-avatar {
        width: 36px;
        height: 36px;
    }

    .chat-header-title-row {
        gap: 6px;
    }

    .key-change-warn {
        max-width: 190px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-tool-btn {
        width: 34px;
        height: 34px;
    }

    .messages-area {
        padding: 18px 12px;
    }

    .message-bubble,
    .group-message-row {
        max-width: 88%;
    }

    .input-area {
        padding: 10px 10px 12px;
    }
}
.modal-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
}
.modal-btn-primary {
    font-size: 13px;
    font-family: var(--font);
    font-weight: 500;
    background: linear-gradient(180deg, var(--accent), var(--accent-deep));
    color: #061426;
    border: none;
    border-radius: 9px;
    padding: 9px 20px;
    cursor: pointer;
    transition: opacity 0.15s;
}
.modal-btn-primary:hover {
    opacity: 0.9;
}
.modal-btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
.modal-btn-secondary {
    font-size: 13px;
    font-family: var(--font);
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border-2);
    border-radius: 9px;
    padding: 9px 18px;
    cursor: pointer;
    transition:
        color 0.15s,
        border-color 0.15s;
}
.modal-btn-secondary:hover {
    color: var(--text);
}
.modal-link {
    background: none;
    border: none;
    color: var(--text-mute);
    font-size: 12px;
    font-family: var(--font);
    cursor: pointer;
    text-align: center;
    padding: 2px 0;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
    align-self: center;
}
.modal-link:hover {
    color: var(--accent);
}
.modal-phrase {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    background: var(--panel-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
    word-break: break-all;
    line-height: 1.7;
    user-select: all;
    cursor: text;
}

.group-manage-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-2);
    border-radius: 8px;
    background: var(--panel-2);
    color: var(--text-dim);
    font: 500 12px var(--font);
    padding: 7px 10px;
    cursor: pointer;
}

.group-panel {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px 18px;
    background: transparent;
}

.group-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin: -2px 0 6px;

    span {
        color: var(--accent);
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }
}

.group-panel-head button,
.group-member-row button,
.group-invite-card button,
.group-panel-section button,
.group-leave-btn {
    border: 1px solid var(--border-2);
    border-radius: 7px;
    background: var(--panel-2);
    color: var(--text-dim);
    font: 500 12px var(--font);
    padding: 6px 8px;
    cursor: pointer;
}

.group-panel-head button {
    width: 42px;
    height: 42px;
    padding: 0;
    border-radius: 14px;
    color: var(--text-mute);
    font-size: 28px;
    line-height: 1;
}

.group-info-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    padding: 18px 0 22px;
    border-bottom: 1px solid var(--border);
    text-align: center;

    strong {
        max-width: 100%;
        color: var(--text);
        font-size: 22px;
        line-height: 1.15;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    input {
        min-width: 0;
        width: 100%;
        border: 0;
        outline: none;
        background: transparent;
        color: var(--text);
        font: 800 22px/1.15 var(--font);
        text-align: center;
    }

    small {
        color: var(--text-dim);
        font-size: 14px;
    }
}

.group-title-inline {
    width: min(100%, 300px);
    min-height: 58px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 42px;
    align-items: center;
    gap: 10px;
    padding: 0 12px 0 24px;
    border: 1px solid transparent;
    border-radius: 18px;
    transition:
        border-color 0.15s,
        background 0.15s,
        box-shadow 0.15s;

    &[data-editing="true"] {
        border-color: rgba(91, 190, 255, 0.45);
        background: rgba(91, 190, 255, 0.045);
        box-shadow: inset 0 0 0 1px rgba(91, 190, 255, 0.08);
    }
}

svg[hidden] {
    display: none;
}

.group-title-edit-btn {
    width: 42px;
    height: 42px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 13px;
    background: transparent;
    color: var(--text-mute);
    cursor: pointer;
    transition:
        color 0.15s,
        background 0.15s;

    &:hover {
        color: var(--accent);
        background: rgba(255, 255, 255, 0.045);
    }
}

.group-info-avatar {
    position: relative;
    width: 92px;
    height: 92px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(91, 190, 255, 0.28);
    border-radius: 32px;
    background:
        radial-gradient(
            circle at 32% 26%,
            rgba(91, 190, 255, 0.26),
            transparent 36%
        ),
        linear-gradient(145deg, rgba(27, 58, 88, 0.9), rgba(16, 27, 46, 0.95));
    color: var(--text);
    font-size: 32px;
    font-weight: 800;
    overflow: hidden;
    cursor: pointer;
}

.group-avatar-camera {
    position: absolute;
    right: 10px;
    bottom: 10px;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(91, 190, 255, 0.3);
    border-radius: 13px;
    background: rgba(9, 14, 24, 0.86);
    color: var(--text);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.28);
}

.group-leave-btn-wrapper {
    padding: 12px;
    border-radius: 20px;
    border: 1px solid rgba(190, 215, 244, 0.1);
    border-color: rgba(239, 130, 125, 0.12);
    background:
        linear-gradient(
            180deg,
            rgba(239, 130, 125, 0.04),
            rgba(255, 255, 255, 0.012)
        ),
        rgba(8, 12, 20, 0.58);
}

.group-panel-section {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.025);
}

.group-panel-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;

    strong {
        display: block;
        color: var(--text);
        font-size: 16px;
        line-height: 1.2;
    }

    small {
        display: block;
        margin-top: 4px;
        color: var(--text-dim);
        font-size: 13px;
    }
}

.group-member-list,
.group-invite-list {
    display: grid;
    gap: 10px;
}

.group-member-row,
.group-invite-friend-row {
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    min-width: 0;
}

.group-member-row {
    position: relative;
    min-height: 64px;
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.025);
    cursor: pointer;
    overflow: visible;
}

.group-member-avatar {
    position: relative;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--border-2);
    background: linear-gradient(
        145deg,
        rgba(28, 63, 96, 0.9),
        rgba(20, 32, 53, 0.95)
    );
    color: var(--text);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
    font-weight: 700;
    overflow: visible;
}

.group-member-online {
    position: absolute;
    right: 1px;
    bottom: 1px;
    width: 10px;
    height: 10px;
    border: 2px solid #0b0f18;
    border-radius: 50%;
    background: var(--green);
    z-index: 2;
    overflow: visible;
}

.group-member-online::before {
    content: "";
    position: absolute;
    inset: -4px;
    z-index: -1;
    border-radius: 50%;
    background: rgba(85, 214, 166, 0.16);
}

.group-member-meta {
    min-width: 0;
    flex: 1;

    span {
        display: block;
        color: var(--text);
        font-size: 14px;
        font-weight: 700;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    small {
        display: block;
        margin-top: 4px;
        color: var(--text-dim);
        font-size: 12px;
    }
}

.group-role-badge {
    max-width: 92px;
    padding: 5px 10px;
    border: 1px solid var(--border-2);
    border-radius: 999px;
    color: var(--text-dim);
    font-size: 11px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.group-member-info {
    display: flex;
    align-items: center;
    width: 100%;
}

.group-member-actions {
    position: absolute;
    top: calc(100% + 8px);
    right: 10px;
    z-index: 30;
    display: none;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
    max-width: calc(100% - 20px);
    padding: 8px;
    border: 1px solid var(--border-2);
    border-radius: 12px;
    background: rgba(12, 16, 25, 0.98);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.38);

    &:empty {
        display: none !important;
    }
}

.group-member-row--actions-open {
    z-index: 35;
    border-color: rgba(91, 190, 255, 0.24);
}

.group-member-row--actions-open .group-member-actions {
    display: flex;
}

.group-member-row--actions-above .group-member-actions {
    top: auto;
    bottom: calc(100% + 8px);
}

.group-invite-card input,
.group-panel-section select {
    min-width: 0;
    flex: 1;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--panel-2);
    color: var(--text);
    font: 12px var(--font);
    padding: 7px 9px;
}

.group-invite-friend-row {
    display: none;

    &.is-open {
        display: flex;
    }
}

.group-invites .group-panel-section-head {
    align-items: flex-start;
}

.group-invites-count {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    min-height: 28px;
    padding: 0 12px;
    border: 1px solid var(--border-2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.035);
    color: var(--text-dim);
    font-size: 13px;
    white-space: nowrap;
}

.group-invite-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
    padding: 12px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.025);
}

.group-invite-card-copy-source {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
}

.group-invite-card-content {
    min-width: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;

    strong,
    small,
    span {
        display: block;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    strong {
        color: var(--text);
        font-size: 15px;
        line-height: 1.25;
    }

    small {
        color: var(--text-dim);
        font-size: 13px;
    }

    span {
        color: #9fcaff;
        font-family: var(--font-mono);
        font-size: 13px;
        letter-spacing: 0.02em;
    }
}

.group-invite-copy-btn {
    width: 48px;
    height: 48px;
    padding: 0;
    border-radius: 16px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}

.group-invite-revoke-btn {
    position: absolute;
    right: 16px;
    bottom: -13px;
    min-height: 26px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
}

.group-invite-card:hover .group-invite-revoke-btn,
.group-invite-revoke-btn:focus-visible {
    opacity: 1;
    pointer-events: auto;
}

.group-link-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.group-panel-empty {
    color: var(--text-mute);
    font-size: 13px;
}

.group-request-row {
    display: flex;
    gap: 10px;
}

.group-request-list {
    display: grid;
    gap: 10px;
    margin-top: 12px;
}

.group-request-row {
    align-items: center;
    justify-content: space-between;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px;
    background: var(--panel-2);
}

.group-request-row strong,
.group-request-row span {
    display: block;
}

.group-request-row strong {
    color: var(--text);
    font-size: 14px;
}

.group-request-row span {
    color: var(--text-mute);
    font-size: 12px;
    margin-top: 2px;
}

.group-request-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.group-friend-picker {
    max-height: 180px;
    overflow: auto;
    display: grid;
    gap: 8px;
}

.group-friend-picker label {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--text-dim);
    font-size: 13px;
}

@media (max-width: 600px) {
    .sidebar {
        width: 100%;
        position: absolute;
        z-index: 10;
    }
    .sidebar.hidden {
        display: none;
    }
}

/* ─── Final redesign corrections after legacy group/mobile rules ─────── */
.modal-btn-primary {
    color: #061426;
}

.modal-input:focus,
.modal-textarea:focus {
    border-color: rgba(91, 190, 255, 0.42);
    box-shadow: 0 0 0 3px rgba(91, 190, 255, 0.08);
}

.group-manage-btn,
.group-panel-head button,
.group-member-row button,
.group-panel-section button,
.group-invite-card,
.group-invite-card button,
.group-invite-card input,
.group-panel-section select,
.group-request-row,
.modal-phrase {
    border-color: rgba(255, 255, 255, 0.085);
    background: rgba(255, 255, 255, 0.04);
}

.group-leave-btn {
    margin-top: auto;
    width: 100%;
    min-height: 42px;
    background: rgba(239, 130, 125, 0.07);
    color: rgba(255, 160, 155, 0.88);
    border: 1px solid rgba(239, 130, 125, 0.2);
    border-radius: 11px;
    transition:
        color 0.16s ease,
        border-color 0.16s ease;

    &:hover {
        color: #ffd6d4;
        background: rgba(239, 130, 125, 0.13);
        border-color: rgba(239, 130, 125, 0.32);
    }
}

.group-panel {
    border-bottom-color: rgba(255, 255, 255, 0.075);
    background: rgba(12, 16, 25, 0.92);
}

.group-member-avatar {
    background: linear-gradient(
        145deg,
        rgba(91, 190, 255, 0.22),
        rgba(91, 190, 255, 0.08)
    );
    border-color: rgba(91, 190, 255, 0.22);
    color: #d8efff;
    overflow: visible;
}

@media (max-width: 720px) {
    .chat-layout {
        width: 100%;
        height: 100dvh;
        margin: 0;
        border-right: 0;
        border-left: 0;
        border-radius: 0;
    }

    .sidebar {
        width: 82px;
        position: relative;
        z-index: 1;
    }

    .sidebar-brand-text,
    .sidebar-search,
    .sidebar-filters,
    .conv-info,
    .conv-time,
    .sidebar-footer,
    .sidebar-new-btn {
        display: none;
    }
}

/* ─── Sidebar-owned navigation, matching Chat.html structure ─────────── */
.chat-layout.chat-shell {
    height: calc(100vh - 28px);
    display: flex;
}

.chat-sidebar {
    width: 382px;
    max-width: 382px;
}

.chat-main {
    min-width: 0;
}

.chat-security-panel {
    margin-bottom: 9px;
    padding: 9px;
    border: 1px solid rgba(185, 211, 242, 0.07);
    border-radius: 16px;
    background:
        linear-gradient(
            180deg,
            rgba(224, 240, 255, 0.032),
            rgba(147, 177, 216, 0.014)
        ),
        rgba(7, 12, 20, 0.42);
}

.section-dock {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 7px;
}

.section-tab {
    position: relative;
    min-width: 0;
    height: 64px;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 5px;
    color: rgba(188, 204, 226, 0.62);
    text-decoration: none;
    border-radius: 16px;
    border: 1px solid transparent;
    background: transparent;
    transition:
        color 0.18s ease,
        background 0.18s ease,
        border-color 0.18s ease,
        box-shadow 0.18s ease,
        transform 0.18s ease;
}

.section-icon {
    position: relative;
    width: 35px;
    height: 35px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background:
        linear-gradient(
            180deg,
            rgba(235, 248, 255, 0.058),
            rgba(123, 160, 204, 0.02)
        ),
        rgba(13, 19, 31, 0.42);
    border: 1px solid rgba(190, 215, 244, 0.06);
    box-shadow:
        inset 0 1px rgba(255, 255, 255, 0.07),
        inset 0 -1px rgba(0, 0, 0, 0.16);
}

.section-icon svg,
.utility-icon svg {
    width: 18px;
    height: 18px;
    display: block;
    stroke-width: 1.72;
}

.section-label {
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 10px;
    line-height: 1;
    font-weight: 620;
    letter-spacing: 0;
}

.section-tab:hover {
    color: rgba(236, 247, 255, 0.92);
    background: rgba(218, 233, 255, 0.045);
    border-color: rgba(190, 215, 244, 0.075);
    transform: translateY(-1px);
}

.section-tab:hover .section-icon {
    border-color: rgba(126, 203, 255, 0.15);
    background:
        linear-gradient(
            180deg,
            rgba(235, 248, 255, 0.095),
            rgba(92, 200, 255, 0.038)
        ),
        rgba(18, 27, 42, 0.52);
}

.section-tab.is-active {
    color: rgba(244, 250, 255, 0.98);
    background:
        radial-gradient(
            circle at 50% 0%,
            rgba(92, 200, 255, 0.13),
            transparent 64%
        ),
        rgba(92, 200, 255, 0.065);
    border-color: rgba(92, 200, 255, 0.16);
    box-shadow: inset 0 1px rgba(255, 255, 255, 0.07);
}

.section-tab.is-active .section-icon {
    color: #eaf8ff;
    background:
        radial-gradient(
            circle at 34% 18%,
            rgba(235, 248, 255, 0.44),
            transparent 30%
        ),
        linear-gradient(
            145deg,
            rgba(119, 216, 255, 0.96),
            rgba(44, 132, 212, 0.94) 64%,
            rgba(18, 58, 101, 0.96)
        );
    border-color: rgba(176, 231, 255, 0.24);
    box-shadow:
        0 10px 22px rgba(92, 200, 255, 0.14),
        inset 0 1px rgba(255, 255, 255, 0.32),
        inset 0 -1px rgba(7, 32, 59, 0.22);
}

.utility-dock {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid rgba(185, 211, 242, 0.065);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
}

.utility-tab,
.sidebar-footer .bell-btn,
.sidebar-footer .profile-menu-toggle {
    min-width: 0;
    width: 100%;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: rgba(184, 201, 223, 0.58);
    text-decoration: none;
    border-radius: 14px;
    border: 1px solid transparent;
    background: transparent;
    font: inherit;
    font-size: 10.4px;
    font-weight: 610;
    letter-spacing: 0;
    cursor: pointer;
    padding: 0 6px;
    transition:
        color 0.18s ease,
        background 0.18s ease,
        border-color 0.18s ease,
        transform 0.18s ease;
}

.utility-tab > span:last-child {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.utility-icon {
    position: relative;
    width: 24px;
    height: 24px;
    flex: 0 0 24px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: rgba(214, 232, 255, 0.035);
    border: 1px solid rgba(190, 215, 244, 0.045);
    overflow: visible;
}

.utility-icon img {
    width: 100%;
    height: 100%;
    border-radius: inherit;
    object-fit: cover;
}

.utility-tab:hover,
.sidebar-footer .bell-btn:hover,
.sidebar-footer .profile-menu-toggle:hover {
    color: rgba(235, 247, 255, 0.86);
    background: rgba(218, 233, 255, 0.04);
    border-color: rgba(190, 215, 244, 0.065);
    transform: translateY(-1px);
}

.utility-tab:hover .utility-icon,
.sidebar-footer .bell-btn:hover .utility-icon,
.sidebar-footer .profile-menu-toggle:hover .utility-icon {
    color: #dff6ff;
    border-color: rgba(126, 203, 255, 0.12);
    background: rgba(92, 200, 255, 0.055);
}

.utility-tab.is-active {
    color: rgba(244, 250, 255, 0.98);
    background: rgba(92, 200, 255, 0.065);
    border-color: rgba(92, 200, 255, 0.16);
}

.section-count,
.sidebar-footer .bell-badge {
    position: absolute;
    top: -6px;
    right: -7px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    color: #061426;
    background: linear-gradient(180deg, #d7f4ff, #59c5ff 66%, #2d86d4);
    border: 2px solid rgba(8, 13, 21, 0.92);
    box-shadow: 0 6px 16px rgba(92, 200, 255, 0.22);
    font-size: 9px;
    font-weight: 800;
    line-height: 1;
}

.chat-profile-menu {
    min-width: 0;
}

.chat-profile-menu .profile-menu {
    top: auto;
    right: 0;
    bottom: calc(100% + 10px);
    z-index: 260;
}

.chat-profile-menu .profile-menu-toggle {
    border-radius: 14px;
}

@media (max-width: 980px) {
    .chat-layout.chat-shell {
        height: calc(100vh - 20px);
    }
}

@media (max-width: 720px) {
    .chat-layout.chat-shell {
        height: 100dvh;
    }

    .chat-sidebar {
        width: 92px;
        max-width: 92px;
    }

    .chat-security-panel,
    .section-dock,
    .utility-dock,
    .sidebar-footer {
        display: none;
    }
}
